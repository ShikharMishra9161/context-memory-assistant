{
  "manifest_version": 3,
  "name": "Context Memory Assistant",
  "version": "1.0.0",
  "description": "Inject your context into AI tools automatically",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/injector-utils.js", "content/chatgpt-injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/injector-utils.js", "content/gemini-injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/injector-utils.js", "content/claude-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
  "default_popup": "popup/index.html"
}
}