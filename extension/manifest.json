{
  "manifest_version": 3,
  "name": "Context Memory Assistant",
  "version": "1.0.0",
  "description": "Inject your context into AI tools automatically",
  "permissions": ["storage", "activeTab", "scripting","alarms"],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://context-memory-api.onrender.com/*"
    
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/injector-utils.js", "content/chatgpt-injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/injector-utils.js", "content/gemini-injector.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/injector-utils.js", "content/claude-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "dist-popup/index.html"
  }
}